{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-start.js",
            "statusMessage": "Loading previous session..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-end.js",
            "async": true
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/cost-tracker.js",
            "async": true
          }
        ]
      }
    ]
  }
}
