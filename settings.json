{
  "permissions": {
    "allow": [
      "mcp__pencil",

      "Bash(gh*)",
      "Bash(cd*&&*gh*)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(git rev-parse*)",
      "Bash(git symbolic-ref*)",
      "Bash(git remote*)",
      "Bash(git ls-files*)",
      "Bash(git shortlog*)",
      "Bash(git branch --list*)",
      "Bash(git branch -a*)",
      "Bash(git branch -r*)",
      "Bash(git tag -l*)",
      "Bash(git tag --list*)",
      "Bash(git config --get*)",

      "Bash(git add *)",
      "Bash(git add .*)",
      "Bash(git add -A*)",
      "Bash(git add -u*)",
      "Bash(git commit -m *)",
      "Bash(git worktree add *)",
      "Bash(git worktree list*)",
      "Bash(git stash*)",
      "Bash(git branch *)",

      "Bash(cd*&&*git status*)",
      "Bash(cd*&&*git diff*)",
      "Bash(cd*&&*git log*)",
      "Bash(cd*&&*git add*)",
      "Bash(cd*&&*git commit -m*)",
      "Bash(git add*&&*git commit -m*)",
      "Bash(git add*&&*git status*)",
      "Bash(git commit*&&*git status*)",
      "Bash(git add*&&*git commit*&&*git status*)"
    ]
  },
  "enabledPlugins": {
    "interface-design@interface-design": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/hooks/statusline-command.js"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-start.js",
            "statusMessage": "Loading previous session..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-end.js",
            "async": true
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/cost-tracker.js",
            "async": true
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": false
}
